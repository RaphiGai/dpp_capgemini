{
  "welcomeFile": "/launchpad/webapp/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/dpp/(.*)$",
      "target": "/dpp/$1",
      "destination": "srv-api",
      "csrfProtection": false,
      "authenticationType": "none"
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "destination": "srv-api",
      "csrfProtection": false,
      "authenticationType": "xsuaa"
    }
  ]
}
