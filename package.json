{
  "name": "dpp-capgemini",
  "version": "0.1.0",
  "description": "Digital Product Passport Backend for Fashion (SAP CAP + Polygon Amoy)",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint \"srv/**/*.js\" \"test/**/*.js\"",
    "format": "prettier --write \"**/*.{js,cds,json,md}\"",
    "deploy:cf": "mbt build && cf deploy mta_archives/dpp-capgemini_0.1.0.mtar"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "bcryptjs": "^2.4.3",
    "cds-swagger-ui-express": "^0.10.0",
    "express": "^4.19.0",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@sap/cds-dk": "^9",
    "axios": "^1.7.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0"
  },
  "cds": {
    "requires": {
      "db": {
        "[development]": "sqlite",
        "[production]": {
          "kind": "hana-cloud"
        }
      }
    }
  }
}
